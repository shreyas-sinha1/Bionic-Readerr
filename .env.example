# Optional path to a locally installed Chromium/Chrome/Edge binary.
# Windows example: C:\Program Files\Google\Chrome\Application\chrome.exe
# Linux Docker example: /usr/bin/chromium
CHROME_EXECUTABLE_PATH=

# Maximum single uploaded file size in bytes. Default: 262144000 (250 MB).
MAX_UPLOAD_BYTES=262144000

# Maximum files per batch. Default: 12.
MAX_BATCH_FILES=12

# Temporary job retention in milliseconds. Default: 3600000 (1 hour).
JOB_TTL_MS=3600000

# Set to true for Docker standalone output.
NEXT_STANDALONE=true
